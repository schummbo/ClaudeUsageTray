<Window
	x:Class="ClaudeUsageTray.Windows.UsagePopup"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Usage"
	Width="240"
	Height="310"
	WindowStyle="None"
	ShowInTaskbar="False"
	Topmost="True"
	Background="Transparent"
	AllowsTransparency="True">
	<Border
		Background="#1a1b2e"
		CornerRadius="12"
		Padding="16">
		<StackPanel Orientation="Vertical">

			<!-- Donut chart with centre text overlaid -->
			<Grid Width="200" Height="200" Margin="0,0,0,12" HorizontalAlignment="Center">
				<Canvas x:Name="DonutCanvas" Width="200" Height="200" Background="Transparent" />
				<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
					<!-- Session % (large) and Weekly % (smaller) side by side -->
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
						<TextBlock x:Name="SessionPctText" FontSize="26" FontWeight="Bold" Foreground="White" VerticalAlignment="Bottom" />
						<TextBlock Text=" / " FontSize="16" Foreground="#555577" VerticalAlignment="Bottom" Margin="2,0,2,2" />
						<TextBlock x:Name="WeeklyPctText" FontSize="18" Foreground="White" VerticalAlignment="Bottom" Margin="0,0,0,1" />
					</StackPanel>
					<TextBlock Text="Session / Weekly" FontSize="10" Foreground="#888888" TextAlignment="Center" Margin="0,2,0,0" />
					<TextBlock x:Name="SessionResetText" FontSize="9" Foreground="#666688" TextAlignment="Center" Margin="0,4,0,0" />
				</StackPanel>
			</Grid>

			<!-- Legend rows -->
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="6" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<Ellipse x:Name="SessionLegendDot" Grid.Row="0" Grid.Column="0" Width="8" Height="8" Fill="#a3e635" Margin="0,0,8,0" VerticalAlignment="Center" />
				<TextBlock Grid.Row="0" Grid.Column="1" Text="Session" Foreground="#cccccc" VerticalAlignment="Center" FontSize="11" />
				<TextBlock Grid.Row="0" Grid.Column="2" x:Name="LegendSessionResetText" Foreground="#888888" VerticalAlignment="Center" FontSize="10" />

				<Ellipse Grid.Row="2" Grid.Column="0" Width="8" Height="8" Fill="#3b82f6" Margin="0,0,8,0" VerticalAlignment="Center" />
				<TextBlock Grid.Row="2" Grid.Column="1" Text="Weekly" Foreground="#cccccc" VerticalAlignment="Center" FontSize="11" />
				<TextBlock Grid.Row="2" Grid.Column="2" x:Name="WeeklyResetText" Foreground="#888888" VerticalAlignment="Center" FontSize="10" />
			</Grid>

		</StackPanel>
	</Border>
</Window>
